DEPLOYMENT=prod
SESSION_SECRET=change-me-in-production

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL — omit in prod; defaults to relative path behind Caddy

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL — omit in prod; defaults to relative path behind Caddy

# --- Pike 13 API ---
# Auth docs: https://developer.pike13.com/docs/authentication
PIKE13_CLIENT_ID=your-pike13-client-id
PIKE13_CLIENT_SECRET=your-pike13-client-secret
PIKE13_ACCESS_TOKEN=your-pike13-access-token
PIKE13_API_BASE=https://YOURSUBDOMAIN.pike13.com/api/v2/desk
# PIKE13_CALLBACK_URL — omit in prod; defaults to relative path behind Caddy

# --- Admin ---
ADMIN_PASSWORD=change-me-in-production

# --- GitHub API (personal access token) ---
GITHUB_TOKEN=your-github-token
GITHUB_STORAGE_REPO=owner/repo-name

# --- AI Services ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
