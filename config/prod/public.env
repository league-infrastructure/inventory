# Docker context for local development
DEV_DOCKER_CONTEXT=default

# Production domain (used by Caddy labels in docker-compose.prod.yml)
APP_DOMAIN=inventory.jointheleague.org

# Production QR code domain
QR_DOMAIN=https://inventory.jointheleague.org

# Production Docker context
PROD_DOCKER_CONTEXT=swarm1

# Database URL for local native dev (Postgres in Docker on host port DB_PORT)
DATABASE_URL=postgresql://app:devpassword@localhost:${DB_PORT:-5433}/app

# Deployment environment
DEPLOYMENT=prod

# OAuth callback URLs (production)
GITHUB_CALLBACK_URL=https://inventory.jointheleague.org/api/auth/github/callback
GOOGLE_CALLBACK_URL=https://inventory.jointheleague.org/api/auth/google/callback
PIKE13_CALLBACK_URL=https://inventory.jointheleague.org/api/auth/pike13/callback
SLACK_APP_ID=A0AK8M9N3SP
SLACK_CLIENT_ID=7071277312.10654723751907

# Pike 13 API base
PIKE13_API_BASE=https://jtl.pike13.com/api/v2/desk

# DigitalOcean Spaces endpoint and bucket (not secret)
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_BUCKET=jtl-inventory
DO_SPACES_REGION=sfo3
