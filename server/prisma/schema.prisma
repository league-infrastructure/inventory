generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Counter {
  id    Int    @id @default(autoincrement())
  name  String @unique
  value Int    @default(0)
}

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Express session store (connect-pg-simple).
// Must match the table structure that connect-pg-simple expects.
model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire])
  @@map("session")
}
