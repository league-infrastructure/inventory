generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Template models ───────────────────────────────────────────────

model Counter {
  id    Int    @id @default(autoincrement())
  name  String @unique
  value Int    @default(0)
}

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Express session store (connect-pg-simple).
// Must match the table structure that connect-pg-simple expects.
model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire])
  @@map("session")
}

// ─── Inventory models ─────────────────────────────────────────────

enum UserRole {
  INSTRUCTOR
  QUARTERMASTER
  ADMIN
}

model User {
  id          Int      @id @default(autoincrement())
  googleId    String?  @unique
  email       String   @unique
  displayName String
  avatar      String?
  role        UserRole @default(INSTRUCTOR)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  custodiedKits      Kit[]      @relation("KitCustodian")
  custodiedComputers Computer[] @relation("ComputerCustodian")
  transfers          Transfer[]
  reportedIssues     Issue[]          @relation("IssueReporter")
  resolvedIssues     Issue[]          @relation("IssueResolver")
  inventoryChecks    InventoryCheck[]
  auditLogs          AuditLog[]
  apiTokens          ApiToken[]
}

model Site {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  address   String?
  latitude  Float?
  longitude Float?
  isHomeSite Boolean @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kits      Kit[]
  computers Computer[]
}

enum KitStatus {
  ACTIVE
  RETIRED
}

enum ContainerType {
  BAG
  LARGE_TOTE
  SMALL_TOTE
  DUFFEL
}

model Kit {
  id            Int           @id @default(autoincrement())
  number        Int           @unique
  containerType ContainerType @default(BAG)
  name          String
  description   String?
  status        KitStatus     @default(ACTIVE)
  qrCode        String?       @unique
  siteId        Int?
  custodianId   Int?
  imageId       Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  site      Site?      @relation(fields: [siteId], references: [id])
  custodian User?      @relation("KitCustodian", fields: [custodianId], references: [id])
  image     Image?     @relation(fields: [imageId], references: [id])
  packs     Pack[]
  computers Computer[]
  inventoryChecks InventoryCheck[] @relation("KitInventoryCheck")

  @@index([siteId])
  @@index([custodianId])
  @@index([imageId])
}

model Pack {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  qrCode      String?  @unique
  kitId       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imageId     Int?

  kit   Kit    @relation(fields: [kitId], references: [id], onDelete: Cascade)
  image Image? @relation(fields: [imageId], references: [id])
  items Item[]
  issues Issue[]
  inventoryChecks InventoryCheck[] @relation("PackInventoryCheck")

  @@index([kitId])
  @@index([imageId])
}

enum ItemType {
  COUNTED
  CONSUMABLE
}

model Item {
  id               Int      @id @default(autoincrement())
  name             String
  type             ItemType
  expectedQuantity Int?
  packId           Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pack   Pack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@index([packId])
}

enum ComputerDisposition {
  ACTIVE
  LOANED
  NEEDS_REPAIR
  IN_REPAIR
  SCRAPPED
  LOST
  DECOMMISSIONED
}

model OperatingSystem {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  computers Computer[]
}

model Computer {
  id              Int                 @id @default(autoincrement())
  serialNumber    String?
  serviceTag      String?
  model           String?
  defaultUsername String?
  defaultPassword String?
  disposition     ComputerDisposition @default(ACTIVE)
  dateReceived    DateTime?
  lastInventoried DateTime?
  notes           String?
  qrCode          String?             @unique
  siteId          Int?
  kitId           Int?
  osId            Int?
  custodianId     Int?
  imageId         Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  site      Site?             @relation(fields: [siteId], references: [id])
  kit       Kit?              @relation(fields: [kitId], references: [id])
  os        OperatingSystem?  @relation(fields: [osId], references: [id])
  custodian User?             @relation("ComputerCustodian", fields: [custodianId], references: [id])
  image     Image?            @relation(fields: [imageId], references: [id])
  hostName  HostName?

  @@index([siteId])
  @@index([kitId])
  @@index([osId])
  @@index([custodianId])
  @@index([imageId])
}

model HostName {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  computerId Int?     @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  computer Computer? @relation(fields: [computerId], references: [id])
}

// Transfer records chain-of-custody changes for kits and computers.
// objectType is 'Kit' or 'Computer', objectId is the entity ID.
model Transfer {
  id             Int       @id @default(autoincrement())
  objectType     String
  objectId       Int
  userId         Int
  fromCustodian  String?
  toCustodian    String?
  fromSiteId     Int?
  toSiteId       Int?
  notes          String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([objectType, objectId])
  @@index([userId])
  @@index([createdAt])
}

enum IssueType {
  MISSING_ITEM
  REPLENISHMENT
}

enum IssueStatus {
  OPEN
  RESOLVED
}

model Issue {
  id         Int         @id @default(autoincrement())
  type       IssueType
  status     IssueStatus @default(OPEN)
  packId     Int
  itemId     Int
  reporterId Int
  resolverId Int?
  notes      String?
  resolvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  pack     Pack  @relation(fields: [packId], references: [id])
  item     Item  @relation(fields: [itemId], references: [id])
  reporter User  @relation("IssueReporter", fields: [reporterId], references: [id])
  resolver User? @relation("IssueResolver", fields: [resolverId], references: [id])

  @@index([packId])
  @@index([status])
}

model InventoryCheck {
  id        Int      @id @default(autoincrement())
  kitId     Int?
  packId    Int?
  userId    Int
  notes     String?
  createdAt DateTime @default(now())

  kit   Kit?  @relation("KitInventoryCheck", fields: [kitId], references: [id])
  pack  Pack? @relation("PackInventoryCheck", fields: [packId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  lines InventoryCheckLine[]

  @@index([kitId])
  @@index([packId])
}

model InventoryCheckLine {
  id               Int     @id @default(autoincrement())
  inventoryCheckId Int
  objectType       String
  objectId         Int
  expectedValue    String?
  actualValue      String?
  hasDiscrepancy   Boolean @default(false)

  inventoryCheck InventoryCheck @relation(fields: [inventoryCheckId], references: [id], onDelete: Cascade)

  @@index([inventoryCheckId])
}

enum AuditSource {
  UI
  IMPORT
  API
  MCP
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  userId     Int?
  objectType String
  objectId   Int
  field      String
  oldValue   String?
  newValue   String?
  source     AuditSource @default(UI)
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([objectType, objectId])
  @@index([userId])
  @@index([createdAt])
}

model ApiToken {
  id          Int        @id @default(autoincrement())
  label       String
  tokenHash   String     @unique
  prefix      String
  userId      Int
  role        UserRole
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model QuartermasterPattern {
  id        Int      @id @default(autoincrement())
  pattern   String
  isRegex   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String?
  objectKey String?
  data      Bytes?
  mimeType  String   @default("image/webp")
  size      Int      @default(0)
  width     Int      @default(0)
  height    Int      @default(0)
  checksum  String   @default("")
  createdAt DateTime @default(now())

  computers Computer[]
  kits      Kit[]
  packs     Pack[]
}
